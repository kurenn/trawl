{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Trawl",
  "version": "0.2.0",
  "identifier": "com.trawl.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Trawl",
        "width": 1200,
        "height": 820,
        "minWidth": 940,
        "minHeight": 640,
        "resizable": true,
        "backgroundColor": "#1b1d23"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "externalBin": ["binaries/rclone"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/kurenn/trawl/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEEyRDEwODlBMThEOTQ3QjcKUldTM1I5a1ltZ2pSb2pCQ2lnZTh3OHIycnZlZGZFb3A3NEJTY2xnNU8rWGI3bnZRR1hoVzgvQzIK"
    }
  }
}
